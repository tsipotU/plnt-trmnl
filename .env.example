# API
PORT_API=3900
DATABASE_PATH=/data/plant-trmnl.db
BACKUP_DIR=/backups
ASSETS_DIR=/app/assets
TZ=Europe/Amsterdam
CALIBRATION_DEADLINE_HOUR=12

# Host path mounted as /backups inside the container. Defaults to ./backups
# relative to the compose file. Override to use a different location, e.g.:
# BACKUP_PATH=/Users/you/Backups/plant-trmnl
# BACKUP_PATH=./backups

# Renderer
PORT_RENDERER=3901
API_INTERNAL_URL=http://plant-api:3900
RENDER_CRON=0 5 * * *

# TRMNL
TRMNL_API_KEY=your-trmnl-api-key
TRMNL_PLUGIN_UUID=your-private-plugin-uuid

# n8n
N8N_ENRICHMENT_WEBHOOK_URL=http://your-n8n-instance/webhook/plant-enrichment
N8N_ENRICHMENT_MAX_RETRIES=10

# Heating season
HEATING_SEASON_START=10-01
HEATING_SEASON_END=04-01

# Dry-soil-aware scheduling (#36)
# Calibration targets "N dry days between waterings." Growing season shortens
# that target (more water); dormancy lengthens it (less water). Heating season
# + growing season stack multiplicatively — see docs/plans/2026-04-24-issue-36-design.md.
GROWING_SEASON_START=04-01
GROWING_SEASON_END=09-30
DRY_DAYS_BASE=7
GROWING_SEASON_MULTIPLIER=0.8
DORMANCY_MULTIPLIER=1.3
